# =========================================================================
# CONFIGURACIÓN GENERAL PARA DOCKER COMPOSE (MeliHub)
# =========================================================================

# --- Configuración de Base de Datos MySQL ---
DB_HOST=db
DB_PORT=3306
DB_NAME=abejas_meliponas
DB_USER=melihub_user
DB_PASSWORD=cambiame_por_seguridad
DB_ROOT_PASSWORD=cambiame_por_seguridad_root

# --- Configuración del Backend ---
PORT=5001
FRONTEND_URL=http://localhost
# URL base pública del backend utilizada para formatear las rutas de las imágenes subidas.
# Nota: Cambiar por tu dominio o IP pública del servidor si es necesario (ej: http://192.168.1.75:5001).
BACKEND_URL=http://localhost:5001

# --- Configuración del Frontend ---
# URL pública del Backend a la que el navegador del cliente hará las peticiones de API.
# NOTA: En un despliegue real, cambiar por la IP pública o dominio del servidor (ej: http://192.168.1.75:5001).
VITE_API_URL=http://localhost:5001

# --- Configuración de Correo SMTP (Opcional, Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion
SMTP_FROM="Soporte MeliHub" <tu-correo@gmail.com>
